{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Build Avalonia Viewer",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"build",
				"KPACS.Viewer.Avalonia/KPACS.Viewer.Avalonia.csproj"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "Start Render Server",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"run",
				"--project",
				"KPACS.RenderServer/KPACS.RenderServer.csproj"
			],
			"isBackground": true,
			"group": "build"
		}
	]
}