{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Grpc": "Information"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Grpc": {
        "Url": "http://0.0.0.0:5200",
        "Protocols": "Http2"
      }
    }
  },
  "RenderServer": {
    "MaxConcurrentSessions": 16,
    "SessionIdleTimeoutMinutes": 30,
    "DefaultJpegQuality": 85,
    "InteractiveJpegQuality": 60,
    "AllowedSeriesPaths": [],
    "ImageboxDatabasePath": ""
  }
}
