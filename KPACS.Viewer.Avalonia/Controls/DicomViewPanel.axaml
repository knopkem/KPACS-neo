<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="KPACS.Viewer.Controls.DicomViewPanel"
             Focusable="True">

    <Grid x:Name="RootGrid" Background="Black" ClipToBounds="True">

        <!-- DICOM image display -->
        <!-- RenderTransformOrigin must be 0,0 (top-left) to match WPF behavior.
             Avalonia defaults to 0.5,0.5 (center), which breaks the zoom/pan math. -->
         <Image x:Name="DicomImage"
             Stretch="Fill"
               HorizontalAlignment="Left"
               VerticalAlignment="Top"
               RenderTransformOrigin="0%,0%"
               RenderOptions.BitmapInterpolationMode="HighQuality" />

        <Canvas x:Name="MeasurementOverlay" IsHitTestVisible="False" />

        <Canvas x:Name="PixelLensOverlay" IsHitTestVisible="False">
            <Border x:Name="PixelLensPanel"
                    Width="144"
                    Height="172"
                    Background="#E0101010"
                    BorderBrush="#FFFFDD00"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="6"
                    IsVisible="False">
                <StackPanel Spacing="6">
                    <Image x:Name="PixelLensImage"
                           Width="128"
                           Height="128"
                           Stretch="Fill"
                           RenderOptions.BitmapInterpolationMode="None" />
                    <TextBlock x:Name="PixelLensText"
                               Foreground="#FFFFDD00"
                               FontFamily="Consolas"
                               FontSize="12"
                               TextAlignment="Center" />
                </StackPanel>
            </Border>
        </Canvas>

        <Canvas x:Name="Cursor3DOverlay" IsHitTestVisible="False">
            <Line x:Name="Cursor3DHorizontal"
                Stroke="#FF35C7FF"
                StrokeThickness="1.5"
                IsVisible="False" />
            <Line x:Name="Cursor3DVertical"
                Stroke="#FF35C7FF"
                StrokeThickness="1.5"
                IsVisible="False" />
            <Ellipse x:Name="Cursor3DMarker"
                   Width="8"
                   Height="8"
                   Stroke="#FF35C7FF"
                   StrokeThickness="1.5"
                   Fill="#4020B8FF"
                   IsVisible="False" />
            </Canvas>

        <Canvas x:Name="ReferenceLineOverlay" IsHitTestVisible="False">
            <Line x:Name="ReferenceLinePrimary"
                Stroke="#FF32D8FF"
                StrokeThickness="1.5"
                StrokeDashArray="10,6"
                IsVisible="False" />
        </Canvas>

        <Button x:Name="ToolboxButton"
                Content="☰"
                Width="30"
                Height="30"
                FontSize="15"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,34"
                Padding="0"
                CornerRadius="15"
                Background="#B0181D24"
                BorderBrush="#8069DFFF"
                BorderThickness="1"
                Foreground="#FFF3F7FF"
                IsVisible="False"
                ToolTip.Tip="Open viewport toolbox"
                Click="OnToolboxButtonClick" />

            <Button x:Name="KeyImageButton"
                Content="🔑"
                Width="28"
                Height="28"
                FontSize="16"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Margin="8,0,0,34"
                Padding="0"
                CornerRadius="14"
                Background="#B0202020"
                BorderBrush="#80909090"
                BorderThickness="1"
                Foreground="#FFB8B8B8"
                IsVisible="False"
                Click="OnKeyImageButtonClick" />

        <!-- Overlay text: 4 corners like a DICOM viewer -->
        <TextBlock x:Name="OverlayTopLeft"
                   Text="" Foreground="#FFFFDD00" FontFamily="Consolas" FontSize="13"
                   VerticalAlignment="Top" HorizontalAlignment="Left"
                   Margin="10" IsHitTestVisible="False" />

        <StackPanel VerticalAlignment="Top"
                HorizontalAlignment="Right"
                Margin="10"
                Spacing="6">
            <TextBlock x:Name="OverlayTopRight"
                   Text="" Foreground="#FFFFDD00" FontFamily="Consolas" FontSize="13"
                   HorizontalAlignment="Right"
                   IsHitTestVisible="False"
                   TextAlignment="Right" />

            <Border x:Name="OrientationBadge"
                Background="#D0151515"
                BorderBrush="#8066D9FF"
                BorderThickness="1"
                CornerRadius="4"
                Padding="8,4"
                HorizontalAlignment="Right"
                IsVisible="False"
                ToolTip.Tip="Left click: switch plane&#10;Right click: choose axial, coronal, or sagittal">
            <TextBlock x:Name="OrientationBadgeText"
                   Text=""
                   Foreground="#FFB9E9FF"
                   FontFamily="Consolas"
                   FontSize="12"
                   FontWeight="SemiBold"
                   TextAlignment="Right" />
            </Border>

            <Border x:Name="ProjectionBadge"
                Background="#D0151515"
                BorderBrush="#80FFDD00"
                BorderThickness="1"
                CornerRadius="4"
                Padding="8,4"
                HorizontalAlignment="Right"
                IsVisible="False"
                ToolTip.Tip="Drag with left click: adjust slab thickness&#10;Right click: choose MPR, MipPR, MinPR, MPVRT, or DVR">
            <TextBlock x:Name="ProjectionBadgeText"
                   Text=""
                   Foreground="#FFFFDD00"
                   FontFamily="Consolas"
                   FontSize="12"
                   FontWeight="SemiBold"
                   TextAlignment="Right" />
            </Border>
        </StackPanel>

        <TextBlock x:Name="OverlayCenterLeft"
               Text="" Foreground="#FFFFDD00" FontFamily="Consolas" FontSize="22" FontWeight="Bold"
               VerticalAlignment="Center" HorizontalAlignment="Left"
               Margin="10,0,0,0" IsHitTestVisible="False" />

        <TextBlock x:Name="OverlayCenterRight"
               Text="" Foreground="#FFFFDD00" FontFamily="Consolas" FontSize="22" FontWeight="Bold"
               VerticalAlignment="Center" HorizontalAlignment="Right"
               Margin="0,0,10,0" IsHitTestVisible="False" TextAlignment="Right" />

        <TextBlock x:Name="OverlayBottomLeft"
                   Text="" Foreground="#FFFFDD00" FontFamily="Consolas" FontSize="13"
                   VerticalAlignment="Bottom" HorizontalAlignment="Left"
                   Margin="10" IsHitTestVisible="False" />

        <TextBlock x:Name="OverlayBottomRight"
                   Text="" Foreground="#FFFFDD00" FontFamily="Consolas" FontSize="13"
                   VerticalAlignment="Bottom" HorizontalAlignment="Right"
                   Margin="10" IsHitTestVisible="False" TextAlignment="Right" />

        <!-- "No image" placeholder -->
        <TextBlock x:Name="PlaceholderText"
                   Text="Drop a DICOM file here or use File → Open"
                   Foreground="#FF666666" FontSize="16"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   IsHitTestVisible="False" />
    </Grid>
</UserControl>
