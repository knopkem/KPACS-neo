<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="KPACS.Viewer.StudyViewerWindow"
        Title="K-PACS Viewer"
    Icon="/Assets/Branding/k-pacs.png"
        Width="1400" Height="900"
        MinWidth="960" MinHeight="700"
        WindowStartupLocation="CenterOwner"
        Background="#FF181818">
    <Window.Styles>
        <Style Selector="Button.viewerAction">
            <Setter Property="Background" Value="#FF1FA2D6" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="MinWidth" Value="86" />
        </Style>
        <Style Selector="ToggleButton.viewerAction">
            <Setter Property="Background" Value="#FF1FA2D6" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="MinWidth" Value="110" />
        </Style>
        <Style Selector="ToggleButton.measureTool">
            <Setter Property="Background" Value="#FF3A3A3A" />
            <Setter Property="Foreground" Value="#FFE5E5E5" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="MinWidth" Value="70" />
        </Style>
        <Style Selector="ToggleButton.measureTool:checked">
            <Setter Property="Background" Value="#FFD9A03C" />
            <Setter Property="Foreground" Value="Black" />
        </Style>
        <Style Selector="ToggleButton.actionMode">
            <Setter Property="Background" Value="#FF323232" />
            <Setter Property="Foreground" Value="#FFF0F0F0" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="MinWidth" Value="96" />
        </Style>
        <Style Selector="ToggleButton.actionMode:checked">
            <Setter Property="Background" Value="#FFD9A03C" />
            <Setter Property="Foreground" Value="Black" />
        </Style>
        <Style Selector="ToggleButton.overlayToggle">
            <Setter Property="Background" Value="#FF323232" />
            <Setter Property="Foreground" Value="#FFF0F0F0" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="MinWidth" Value="96" />
        </Style>
        <Style Selector="ToggleButton.overlayToggle:checked">
            <Setter Property="Background" Value="#FF35C7FF" />
            <Setter Property="Foreground" Value="Black" />
        </Style>
        <Style Selector="ToggleButton.iconToggle">
            <Setter Property="Background" Value="#FF323232" />
            <Setter Property="Foreground" Value="#FFF0F0F0" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="MinWidth" Value="46" />
            <Setter Property="FontSize" Value="16" />
        </Style>
        <Style Selector="ToggleButton.iconToggle:checked">
            <Setter Property="Background" Value="#FF35C7FF" />
            <Setter Property="Foreground" Value="Black" />
        </Style>
        <Style Selector="Button.popupAction">
            <Setter Property="Background" Value="#FF2E2E2E" />
            <Setter Property="Foreground" Value="#FFF2F2F2" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>
        <Style Selector="Button.topBarAction">
            <Setter Property="Background" Value="#FF1B3A4A" />
            <Setter Property="Foreground" Value="#FFF4FAFF" />
            <Setter Property="BorderBrush" Value="#FF76C8FF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="38" />
        </Style>
        <Style Selector="Button.workspaceAction">
            <Setter Property="Background" Value="#FF20262D" />
            <Setter Property="Foreground" Value="#FFF0F5FA" />
            <Setter Property="BorderBrush" Value="#554F617E" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="11" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="MinHeight" Value="24" />
            <Setter Property="MinWidth" Value="78" />
            <Setter Property="FontSize" Value="11" />
        </Style>
        <Style Selector="Button.workspaceAction:pointerover">
            <Setter Property="Background" Value="#FF283540" />
            <Setter Property="BorderBrush" Value="#FF76C8FF" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="MinWidth" Value="108" />
        </Style>
        <Style Selector="Button.workspaceAction:disabled">
            <Setter Property="Opacity" Value="0.55" />
        </Style>
        <Style Selector="Border.workspaceDock">
            <Setter Property="Background" Value="#A811151A" />
            <Setter Property="BorderBrush" Value="#66303840" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="6,3" />
            <Setter Property="Opacity" Value="0.58" />
        </Style>
        <Style Selector="Border.workspaceDock:pointerover">
            <Setter Property="Background" Value="#DD11151A" />
            <Setter Property="BorderBrush" Value="#AA76C8FF" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Opacity" Value="0.96" />
        </Style>
        <Style Selector="Button.workspaceTeaser">
            <Setter Property="Background" Value="#A811151A" />
            <Setter Property="Foreground" Value="#FFDCEFFF" />
            <Setter Property="BorderBrush" Value="#77546C84" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="0,0,10,10" />
            <Setter Property="Padding" Value="10,1,10,3" />
            <Setter Property="MinWidth" Value="34" />
            <Setter Property="Height" Value="18" />
            <Setter Property="Opacity" Value="0.84" />
        </Style>
        <Style Selector="Button.workspaceTeaser:pointerover">
            <Setter Property="Background" Value="#DD11151A" />
            <Setter Property="BorderBrush" Value="#AA76C8FF" />
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="TextBlock.popupSectionTitle">
            <Setter Property="Foreground" Value="#FFBDBDBD" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#FF2A2A2A" />
            <Setter Property="Foreground" Value="#FFF2F2F2" />
            <Setter Property="BorderBrush" Value="#FF6A6A6A" />
            <Setter Property="CaretBrush" Value="#FF35C7FF" />
            <Setter Property="SelectionBrush" Value="#6655A8FF" />
        </Style>
        <Style Selector="TextBox:focus">
            <Setter Property="BorderBrush" Value="#FF7FD9FF" />
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="Background" Value="#FF20262D" />
            <Setter Property="Foreground" Value="#FFF2F6FA" />
            <Setter Property="BorderBrush" Value="#FF5D768E" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="FontSize" Value="11" />
        </Style>
        <Style Selector="ComboBox:pointerover">
            <Setter Property="BorderBrush" Value="#FF7FD9FF" />
        </Style>
        <Style Selector="ComboBox:focus">
            <Setter Property="BorderBrush" Value="#FF7FD9FF" />
        </Style>
        <Style Selector="ComboBoxItem">
            <Setter Property="Background" Value="#FF20262D" />
            <Setter Property="Foreground" Value="#FFF2F6FA" />
            <Setter Property="Padding" Value="8,4" />
        </Style>
        <Style Selector="ComboBoxItem:pointerover">
            <Setter Property="Background" Value="#FF2B3946" />
            <Setter Property="Foreground" Value="#FFF6FBFF" />
        </Style>
        <Style Selector="ComboBoxItem:selected">
            <Setter Property="Background" Value="#FF355369" />
            <Setter Property="Foreground" Value="#FFF6FBFF" />
        </Style>
        <Style Selector="ScrollBar">
            <Setter Property="Background" Value="#FF2A2A2A" />
            <Setter Property="Foreground" Value="#FFB8B8B8" />
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="ScrollBar:pointerover">
            <Setter Property="Foreground" Value="#FFF0F0F0" />
        </Style>
        <Style Selector="ToggleButton.toolboxChip">
            <Setter Property="Background" Value="#2A2F3A" />
            <Setter Property="Foreground" Value="#FFF2F4F8" />
            <Setter Property="BorderBrush" Value="#554F617E" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinWidth" Value="44" />
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="ToggleButton.toolboxChip:checked">
            <Setter Property="Background" Value="#FF2C93B7" />
            <Setter Property="Foreground" Value="#FFF7FBFF" />
            <Setter Property="BorderBrush" Value="#FF92E6FF" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,Auto,*">
        <Border Grid.Row="0" Background="#FF2A2A2A" Padding="10,8">
            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto,Auto">
                <TextBlock x:Name="StudyTitleText"
                           FontSize="18" FontWeight="SemiBold" Foreground="White" />
                <Border Grid.Column="1"
                        Background="#FF224C69"
                        BorderBrush="#FF76C8FF"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="10,4"
                        VerticalAlignment="Center"
                        Margin="12,0,0,0">
                    <TextBlock x:Name="ViewerIdentityText"
                               Foreground="White"
                               FontSize="12"
                               FontWeight="SemiBold" />
                </Border>
                <Button x:Name="TopBarStudyBrowserButton"
                        Grid.Column="2"
                        Classes="topBarAction"
                        Margin="10,0,0,0"
                        Click="OnStudyBrowserClick"
                        ToolTip.Tip="Bring the Study Browser to the front." />
                <TextBlock x:Name="StudySubtitleText" Grid.Row="1" Grid.ColumnSpan="3" Margin="0,6,0,0"
                           Foreground="#FFAAAAAA" FontSize="12" />
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="#FF0F0F0F" BorderBrush="#FF4A4A4A" BorderThickness="0,0,0,1" Padding="8,6">
            <Grid RowDefinitions="Auto,Auto">
                <ScrollViewer x:Name="PriorStudiesScrollViewer"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled"
                              IsVisible="False"
                              Margin="0,0,0,6">
                    <StackPanel x:Name="PriorStudiesPanel" Orientation="Horizontal" Spacing="8" />
                </ScrollViewer>

                <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="ThumbnailStripPanel" Orientation="Horizontal" Spacing="8" />
                </ScrollViewer>
            </Grid>
        </Border>

          <Grid Grid.Row="2" x:Name="ViewerContentHost"
              PointerMoved="OnViewerContentPointerMoved"
              PointerEntered="OnViewerContentPointerEntered"
              PointerExited="OnViewerContentPointerExited">
            <Border Background="#FF101010" Padding="8">
                <Grid>
                    <Grid x:Name="ViewportGrid" ClipToBounds="True" />
                    <Canvas x:Name="DragGhostOverlay" IsHitTestVisible="False" ClipToBounds="False" />
                </Grid>
            </Border>

            <Border x:Name="WorkspaceDock"
                    Classes="workspaceDock"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Margin="0,10,0,0"
                    ZIndex="5"
                    PointerEntered="OnWorkspaceDockPointerEntered"
                    PointerExited="OnWorkspaceDockPointerExited">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                    <TextBlock Text="Workspace"
                               VerticalAlignment="Center"
                               Foreground="#FF97A8B7"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Margin="2,0,2,0" />
                    <WrapPanel Grid.Column="1" Orientation="Horizontal" ItemWidth="104">
                        <Button x:Name="WorkspaceLayoutButton" Classes="workspaceAction" Click="OnWorkspaceLayoutClick" ToolTip.Tip="Viewer layout presets and custom layouts." />
                        <Button x:Name="WorkspaceReportButton" Classes="workspaceAction" Click="OnWorkspaceReportClick" ToolTip.Tip="Open the floating report panel with created findings, source provenance, and anatomy hints.">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <TextBlock Text="RP" FontWeight="SemiBold" FontSize="11" />
                                <TextBlock Text="Report" FontSize="11" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="WorkspaceHangingProtocolsButton" Classes="workspaceAction" IsEnabled="False" ToolTip.Tip="Reserved for hanging protocols.">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <TextBlock Text="HP" FontWeight="SemiBold" FontSize="11" />
                                <TextBlock Text="Hanging" FontSize="11" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="WorkspaceSettingsButton" Classes="workspaceAction" IsEnabled="False" ToolTip.Tip="Reserved for viewer settings.">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <TextBlock Text="⚙" FontSize="11" />
                                <TextBlock Text="Settings" FontSize="11" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="WorkspacePluginsButton" Classes="workspaceAction" IsEnabled="False" ToolTip.Tip="Reserved for plugin actions.">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <TextBlock Text="🧩" FontSize="11" />
                                <TextBlock Text="Plugins" FontSize="11" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="WorkspaceExportButton" Classes="workspaceAction" IsEnabled="False" ToolTip.Tip="Reserved for export actions.">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <TextBlock Text="⬆" FontSize="11" />
                                <TextBlock Text="Export" FontSize="11" />
                            </StackPanel>
                        </Button>
                    </WrapPanel>
                </Grid>
            </Border>

            <Button x:Name="WorkspaceDockRevealButton"
                    Classes="workspaceTeaser"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Margin="0,0,0,0"
                    ZIndex="6"
                    IsVisible="False"
                    Content="⌄"
                    Click="OnWorkspaceDockRevealClick"
                    PointerEntered="OnWorkspaceDockRevealPointerEntered"
                    ToolTip.Tip="Show workspace actions" />

                <Border x:Name="ActionToolbarBorder"
                    IsVisible="False"
                    Background="#EE202020"
                    BorderBrush="#FF4A4A4A"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="12,10"
                    Margin="12"
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Center"
                    Opacity="0"
                    IsHitTestVisible="False"
                    PointerEntered="OnActionToolbarPointerEntered"
                    PointerExited="OnActionToolbarPointerExited">
                <Grid ColumnDefinitions="*,*,*,*,*,Auto,Auto,Auto" ColumnSpacing="10">
                    <ToggleButton x:Name="ActionScrollButton" Classes="actionMode" Content="Scroll/Stack" Click="OnActionScrollClick" />
                    <ToggleButton x:Name="ActionZoomPanButton" Grid.Column="1" Classes="actionMode" Content="Zoom-Pan" Click="OnActionZoomPanClick" />
                    <ToggleButton x:Name="ActionWindowButton" Grid.Column="2" Classes="actionMode" Content="Window" Click="OnActionWindowClick" />
                    <ToggleButton x:Name="ActionToolsButton" Grid.Column="3" Classes="actionMode" Content="Tools" Click="OnActionToolsClick" />
                    <ToggleButton x:Name="ActionLayoutButton" Grid.Column="4" Classes="actionMode" Content="Layout" Click="OnActionLayoutClick" />
                    <ToggleButton x:Name="LinkedSyncToggleButton" Grid.Column="5" Classes="iconToggle" Content="⛓" IsChecked="True" Click="OnLinkedSyncToggleClick" ToolTip.Tip="Synchronize compatible views in the same 3D space." />
                    <ToggleButton x:Name="OverlayToggleButton" Grid.Column="6" Classes="overlayToggle" Content="Overlay" IsChecked="True" Click="OnOverlayToggleClick" />
                    <Button x:Name="StudyBrowserButton" Grid.Column="7" Classes="popupAction" Content="Study Browser" Click="OnStudyBrowserClick" ToolTip.Tip="Bring the Study Browser window to the front." />
                </Grid>
            </Border>

            <TextBlock x:Name="ViewerStatusText"
                       IsVisible="False"
                       Width="0"
                       Height="0" />

                <Border x:Name="MeasurementInsightPanel"
                    IsVisible="False"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,18,18"
                    Padding="12"
                    MaxWidth="360"
                    MinWidth="280"
                    Background="#E6141820"
                    BorderBrush="#805E7FA4"
                    BorderThickness="1"
                    CornerRadius="12"
                    ZIndex="4">
                <Border.RenderTransform>
                    <TranslateTransform />
                </Border.RenderTransform>
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                        <StackPanel x:Name="MeasurementInsightDragHandle"
                                    Spacing="2"
                                    Cursor="SizeAll"
                                    PointerPressed="OnMeasurementInsightHeaderPointerPressed"
                                    PointerMoved="OnMeasurementInsightHeaderPointerMoved"
                                    PointerReleased="OnMeasurementInsightHeaderPointerReleased">
                            <TextBlock x:Name="MeasurementInsightTitleText"
                                       Foreground="#FFF6FBFF"
                                       FontWeight="SemiBold"
                                       FontSize="13" />
                            <TextBlock x:Name="MeasurementInsightSeriesText"
                                       Foreground="#FF9DB3C7"
                                       FontSize="11"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleButton x:Name="MeasurementInsightPinButton"
                                      Grid.Column="1"
                                      Classes="iconToggle"
                                      Width="30"
                                      Height="30"
                                      MinWidth="30"
                                      Click="OnMeasurementInsightPinClick"
                                      ToolTip.Tip="Pin the ROI panel and retain the last measurement details." />
                        <ToggleButton x:Name="MeasurementInsightCollapseButton"
                                      Grid.Column="2"
                                      Classes="iconToggle"
                                      Width="30"
                                      Height="30"
                                      MinWidth="30"
                                      Click="OnMeasurementInsightCollapseClick"
                                      ToolTip.Tip="Collapse or expand the ROI histogram section." />
                    </Grid>

                    <Border Height="1" Background="#334D5F74" />

                    <StackPanel x:Name="MeasurementInsightBodyPanel"
                                Spacing="8">
                    <StackPanel Spacing="3">
                        <TextBlock x:Name="MeasurementInsightStatsText"
                                   Foreground="#FFF1F6AA"
                                   FontSize="11"
                                   TextWrapping="Wrap" />
                        <TextBlock x:Name="MeasurementInsightRangeText"
                                   Foreground="#FFAEC2D3"
                                   FontSize="10"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                        <Grid x:Name="MeasurementInsightCorrectionRow"
                          IsVisible="False"
                          ColumnDefinitions="Auto,Auto,*"
                          ColumnSpacing="8">
                        <Button x:Name="MeasurementInsightShrinkButton"
                            Content="Shrink"
                            MinWidth="68"
                            Click="OnMeasurementInsightShrinkClick"
                            ToolTip.Tip="Reduce polygon auto-outline sensitivity to shrink the selected ROI." />
                        <Button x:Name="MeasurementInsightGrowButton"
                            Grid.Column="1"
                            Content="Grow"
                            MinWidth="68"
                            Click="OnMeasurementInsightGrowClick"
                            ToolTip.Tip="Increase polygon auto-outline sensitivity to grow the selected ROI." />
                        <TextBlock x:Name="MeasurementInsightCorrectionText"
                               Grid.Column="2"
                               VerticalAlignment="Center"
                               Foreground="#FFD3E5F5"
                               FontSize="10"
                               TextWrapping="Wrap"
                               Text="Sensitivity: default" />
                        </Grid>

                    <Border Background="#20000000"
                            BorderBrush="#33394B61"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="8,6">
                        <Grid RowDefinitions="*,Auto" RowSpacing="4">
                            <Canvas x:Name="MeasurementInsightHistogramCanvas"
                                    Width="320"
                                    Height="120" />
                            <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                <TextBlock x:Name="MeasurementInsightAxisMinText"
                                           Foreground="#FF9DB3C7"
                                           FontSize="10" />
                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            Spacing="10">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <Border Width="10" Height="10" CornerRadius="5" Background="#FF7FDFA2" />
                                        <TextBlock Text="P10" Foreground="#FFD3E5F5" FontSize="10" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <Border Width="10" Height="10" CornerRadius="5" Background="#FFFFD86B" />
                                        <TextBlock Text="Median" Foreground="#FFD3E5F5" FontSize="10" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <Border Width="10" Height="10" CornerRadius="5" Background="#FFFF8A8A" />
                                        <TextBlock Text="P90" Foreground="#FFD3E5F5" FontSize="10" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <Border Width="16" Height="2" VerticalAlignment="Center" Background="#CCFFD56B" />
                                        <TextBlock Text="Trend" Foreground="#FFD3E5F5" FontSize="10" />
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock x:Name="MeasurementInsightAxisMaxText"
                                           Grid.Column="2"
                                           Foreground="#FF9DB3C7"
                                           FontSize="10"
                                           HorizontalAlignment="Right" />
                            </Grid>
                        </Grid>
                    </Border>

                    <TextBlock x:Name="MeasurementInsightSupplementText"
                               Foreground="#FFD3E5F5"
                               FontSize="10"
                               TextWrapping="Wrap" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border x:Name="VolumeRoiDraftPanel"
                    IsVisible="False"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Margin="18,0,0,18"
                    Padding="12"
                    MaxWidth="360"
                    MinWidth="280"
                    Background="#E6141820"
                    BorderBrush="#806D9ED6"
                    BorderThickness="1"
                    CornerRadius="12"
                    ZIndex="4">
                <Border.RenderTransform>
                    <TranslateTransform />
                </Border.RenderTransform>
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                        <StackPanel x:Name="VolumeRoiDraftDragHandle"
                                    Spacing="2"
                                    Cursor="SizeAll"
                                    PointerPressed="OnVolumeRoiDraftHeaderPointerPressed"
                                    PointerMoved="OnVolumeRoiDraftHeaderPointerMoved"
                                    PointerReleased="OnVolumeRoiDraftHeaderPointerReleased">
                            <TextBlock x:Name="VolumeRoiDraftTitleText"
                                       Text="3D ROI draft"
                                       Foreground="#FFF6FBFF"
                                       FontWeight="SemiBold"
                                       FontSize="13" />
                        </StackPanel>
                        <ToggleButton x:Name="VolumeRoiAddButton"
                                      Grid.Column="1"
                                      Content="Add"
                                      Width="44"
                                      Height="26"
                                      MinWidth="44"
                                      Margin="0,0,10,0"
                                      Click="OnVolumeRoiAddClick"
                                      ToolTip.Tip="Add another region to the 3D ROI draft instead of replacing the current slice contour." />
                        <ToggleButton x:Name="VolumeRoiDraftPinButton"
                                      Grid.Column="2"
                                      Classes="iconToggle"
                                      Width="30"
                                      Height="30"
                                      MinWidth="30"
                                      Click="OnVolumeRoiPreviewPinClick"
                                      ToolTip.Tip="Pin the 3D ROI model panel and retain the last preview." />
                    </Grid>
                    <TextBlock x:Name="VolumeRoiDraftStatusText"
                               Foreground="#FF9DB3C7"
                               FontSize="11"
                               TextWrapping="Wrap" />
                        <Grid x:Name="VolumeRoiDraftCorrectionRow"
                          IsVisible="False"
                          ColumnDefinitions="Auto,Auto,*"
                          ColumnSpacing="8">
                        <Button x:Name="VolumeRoiShrinkButton"
                            Content="Shrink"
                            MinWidth="68"
                            Click="OnVolumeRoiShrinkClick"
                            ToolTip.Tip="Reduce auto-outline sensitivity to shrink the 3D ROI draft." />
                        <Button x:Name="VolumeRoiGrowButton"
                            Grid.Column="1"
                            Content="Grow"
                            MinWidth="68"
                            Click="OnVolumeRoiGrowClick"
                            ToolTip.Tip="Increase auto-outline sensitivity to grow the 3D ROI draft." />
                        <TextBlock x:Name="VolumeRoiCorrectionText"
                               Grid.Column="2"
                               VerticalAlignment="Center"
                               Foreground="#FFD3E5F5"
                               FontSize="10"
                               TextWrapping="Wrap"
                               Text="Sensitivity: default" />
                        </Grid>
                    <Border Height="1" Background="#334D5F74" />
                    <Border Background="#20000000"
                            BorderBrush="#33394B61"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="8,6">
                        <Canvas x:Name="VolumeRoiDraftCanvas"
                                Width="320"
                                Height="160" />
                    </Border>
                    <TextBlock x:Name="VolumeRoiDraftHintText"
                               Foreground="#FFD3E5F5"
                               FontSize="10"
                               TextWrapping="Wrap"
                               Text="Click to place points, double-click without a line to auto-outline, or double-click with a line to close a slice contour. Scroll to another slice, use arrow keys to rotate the mesh preview, then press Enter to finish or Esc to cancel." />
                </StackPanel>
            </Border>

            <Border x:Name="ReportPanel"
                    IsVisible="False"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,72,18,0"
                    Padding="12"
                    MaxWidth="420"
                    MinWidth="320"
                    Background="#E6141820"
                    BorderBrush="#807FC891"
                    BorderThickness="1"
                    CornerRadius="12"
                    ZIndex="4">
                <Border.RenderTransform>
                    <TranslateTransform />
                </Border.RenderTransform>
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <StackPanel x:Name="ReportPanelDragHandle"
                                    Spacing="2"
                                    Cursor="SizeAll"
                                    PointerPressed="OnReportPanelHeaderPointerPressed"
                                    PointerMoved="OnReportPanelHeaderPointerMoved"
                                    PointerReleased="OnReportPanelHeaderPointerReleased">
                            <TextBlock Text="Report"
                                       Foreground="#FFF6FBFF"
                                       FontWeight="SemiBold"
                                       FontSize="13" />
                            <TextBlock x:Name="ReportPanelSummaryText"
                                       Foreground="#FF9DB3C7"
                                       FontSize="11"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleButton x:Name="ReportPanelPinButton"
                                      Grid.Column="1"
                                      Classes="iconToggle"
                                      Width="30"
                                      Height="30"
                                      MinWidth="30"
                                      Click="OnReportPanelPinClick"
                                      ToolTip.Tip="Pin the report panel and keep it open for the current workspace." />
                    </Grid>

                    <Border Height="1" Background="#334D5F74" />

                    <TextBlock x:Name="ReportPanelHintText"
                               Foreground="#FFD3E5F5"
                               FontSize="10"
                               TextWrapping="Wrap" />

                    <ScrollViewer MaxHeight="480"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="ReportItemsPanel"
                                    Spacing="8" />
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <Popup x:Name="ViewportToolboxPopup"
                   Placement="Bottom"
                   HorizontalOffset="0"
                   VerticalOffset="8"
                   IsLightDismissEnabled="True"
                   Closed="OnViewportToolboxPopupClosed">
                <Border Background="#E61B2028"
                        BorderBrush="#667AA6D9"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="14,12"
                        MaxWidth="520"
                        BoxShadow="0 14 36 0 #70000000">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Viewport toolbox"
                                   Foreground="#FFF2F4F8"
                                   FontWeight="SemiBold"
                                   FontSize="13" />

                        <WrapPanel ItemWidth="50" Orientation="Horizontal">
                            <ToggleButton x:Name="ToolboxNavigateButton" Classes="toolboxChip" Content="Navigate" Click="OnNavigateToolClick" />
                            <ToggleButton x:Name="ToolboxPixelLensButton" Classes="toolboxChip" Content="Pixel lens" Tag="PixelLens" Click="OnMeasurementToolPopupClick" />
                            <ToggleButton x:Name="ToolboxLineButton" Classes="toolboxChip" Content="Line" Tag="Line" Click="OnMeasurementToolPopupClick" />
                            <ToggleButton x:Name="ToolboxAngleButton" Classes="toolboxChip" Content="Angle" Tag="Angle" Click="OnMeasurementToolPopupClick" />
                            <ToggleButton x:Name="ToolboxAnnotationButton" Classes="toolboxChip" Content="Text" Tag="Annotation" Click="OnMeasurementToolPopupClick" />
                            <ToggleButton x:Name="ToolboxRectangleRoiButton" Classes="toolboxChip" Content="Rect ROI" Tag="RectangleRoi" Click="OnMeasurementToolPopupClick" />
                            <ToggleButton x:Name="ToolboxEllipseRoiButton" Classes="toolboxChip" Content="Ellipse ROI" Tag="EllipseRoi" Click="OnMeasurementToolPopupClick" />
                            <ToggleButton x:Name="ToolboxPolygonRoiButton" Classes="toolboxChip" Content="Polygon ROI" Tag="PolygonRoi" Click="OnMeasurementToolPopupClick" />
                            <ToggleButton x:Name="ToolboxVolumeRoiButton" Classes="toolboxChip" Content="3D ROI" Tag="VolumeRoi" Click="OnMeasurementToolPopupClick" ToolTip.Tip="Draw a volumetric ROI across slices. Double-click without a line auto-outlines the structure, double-click with a line closes the contour, use Add in the preview panel to merge another region, and Enter finishes the 3D ROI." />
                            <ToggleButton x:Name="ToolboxBallRoiButton" Classes="toolboxChip" Content="ROI ball" Tag="BallRoiCorrection" Click="OnMeasurementToolPopupClick" ToolTip.Tip="Sculpt polygon or 3D ROI edges with a circular brush. Drag from inside for dents, from outside for bulges. Use CTRL+wheel or [ and ] to change the radius." />
                            <ToggleButton x:Name="ToolboxModifyButton" Classes="toolboxChip" Content="Modify" Tag="Modify" Click="OnMeasurementToolPopupClick" ToolTip.Tip="Select and edit measurements. Arrow keys nudge the selected measurement; hold SHIFT for larger steps." />
                            <ToggleButton x:Name="ToolboxEraseButton" Classes="toolboxChip" Content="Erase" Tag="Erase" Click="OnMeasurementToolPopupClick" />
                        </WrapPanel>

                        <Border Height="1" Background="#334D5F74" />

                        <StackPanel Spacing="6">
                            <TextBlock Text="Research"
                                       Foreground="#FFB9C4D1"
                                       FontSize="11"
                                       FontWeight="SemiBold" />
                            <Button x:Name="ToolboxRecistSuggestButton"
                                    Classes="popupAction"
                                    Content="Suggest RECIST follow-up"
                                    Click="OnToolboxRecistSuggestClick"
                                    ToolTip.Tip="Use the selected baseline line or ROI and create a suggested follow-up lesion in this viewport's loaded series." />
                        </StackPanel>

                        <Border Height="1" Background="#334D5F74" />

                        <StackPanel Spacing="6">
                            <TextBlock Text="View"
                                       Foreground="#FFB9C4D1"
                                       FontSize="11"
                                       FontWeight="SemiBold" />
                            <WrapPanel ItemWidth="56" Orientation="Horizontal">
                                <ToggleButton x:Name="ToolboxOverlayToggleButton" Classes="toolboxChip" Content="Overlay" Click="OnToolboxOverlayToggleClick" />
                            </WrapPanel>
                        </StackPanel>

                        <Border Height="1" Background="#334D5F74" />

                        <StackPanel Spacing="6">
                            <TextBlock Text="Linking"
                                       Foreground="#FFB9C4D1"
                                       FontSize="11"
                                       FontWeight="SemiBold" />
                            <WrapPanel ItemWidth="56" Orientation="Horizontal">
                                <ToggleButton x:Name="Toolbox3DCursorButton" Classes="toolboxChip" Click="OnToolbox3DCursorClick" />
                                <ToggleButton x:Name="ToolboxLinkedSyncToggleButton" Classes="toolboxChip" Content="Linked sync" Click="OnToolboxLinkedSyncToggleClick" />
                            </WrapPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Popup>
            <ItemsControl x:Name="ToastItemsControl"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Top"
                          Margin="0,16,16,0"
                          IsHitTestVisible="False">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Spacing="8" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{Binding Background}"
                                BorderBrush="{Binding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="10,8"
                                MinWidth="260"
                                MaxWidth="420"
                                BoxShadow="0 8 20 0 #50000000">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                <TextBlock Text="{Binding Icon}"
                                           FontSize="16"
                                           VerticalAlignment="Top"
                                           Foreground="{Binding Foreground}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Message}"
                                           TextWrapping="Wrap"
                                           Foreground="{Binding Foreground}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Popup x:Name="WindowPresetPopup" Placement="Top" IsLightDismissEnabled="True" Closed="OnAnyActionPopupClosed">
                <Border Background="#F0262626" BorderBrush="#FF5A5A5A" BorderThickness="1" CornerRadius="8" Padding="8"
                        PointerEntered="OnActionToolbarPointerEntered" PointerExited="OnActionToolbarPointerExited">
                    <StackPanel Width="364" Spacing="10">
                        <StackPanel Spacing="6">
                            <TextBlock Classes="popupSectionTitle" Text="Window" />
                            <WrapPanel ItemWidth="110" Orientation="Horizontal">
                                <Button Classes="popupAction" Content="Brain" Tag="40|80" Click="OnWindowPresetSelected" />
                                <Button Classes="popupAction" Content="Abdomen" Tag="60|400" Click="OnWindowPresetSelected" />
                                <Button Classes="popupAction" Content="Lung" Tag="-600|1500" Click="OnWindowPresetSelected" />
                                <Button Classes="popupAction" Content="Bone" Tag="300|2000" Click="OnWindowPresetSelected" />
                                <Button Classes="popupAction" Content="Reset" Tag="RESET" Click="OnWindowPresetSelected" />
                            </WrapPanel>
                        </StackPanel>

                        <Border Height="1" Background="#404A4A4A" />

                        <StackPanel Spacing="6">
                            <TextBlock Classes="popupSectionTitle" Text="LUT" />
                            <WrapPanel ItemWidth="110" Orientation="Horizontal">
                                <Button Classes="popupAction" Content="Grayscale" Tag="1" Click="OnWindowLutSelected" />
                                <Button Classes="popupAction" Content="Inverted" Tag="-1" Click="OnWindowLutSelected" />
                                <Button Classes="popupAction" Content="Hot Iron" Tag="2" Click="OnWindowLutSelected" />
                                <Button Classes="popupAction" Content="Rainbow" Tag="3" Click="OnWindowLutSelected" />
                                <Button Classes="popupAction" Content="Gold" Tag="5" Click="OnWindowLutSelected" />
                                <Button Classes="popupAction" Content="Bone" Tag="10" Click="OnWindowLutSelected" />
                            </WrapPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Popup>

            <Popup x:Name="ToolsPopup" Placement="Top" IsLightDismissEnabled="True" Closed="OnAnyActionPopupClosed">
                <Border Background="#F0262626" BorderBrush="#FF5A5A5A" BorderThickness="1" CornerRadius="8" Padding="8"
                        PointerEntered="OnActionToolbarPointerEntered" PointerExited="OnActionToolbarPointerExited">
                    <StackPanel Width="190" Spacing="6">
                        <Button Classes="popupAction" Content="Line" Tag="Line" Click="OnMeasurementToolPopupClick" />
                        <Button Classes="popupAction" Content="Angle" Tag="Angle" Click="OnMeasurementToolPopupClick" />
                        <Button Classes="popupAction" Content="Annotation" Tag="Annotation" Click="OnMeasurementToolPopupClick" />
                        <Button Classes="popupAction" Content="Rectangle ROI" Tag="RectangleRoi" Click="OnMeasurementToolPopupClick" />
                        <Button Classes="popupAction" Content="Ellipse ROI" Tag="EllipseRoi" Click="OnMeasurementToolPopupClick" />
                        <Button Classes="popupAction" Content="Polygon ROI" Tag="PolygonRoi" Click="OnMeasurementToolPopupClick" />
                        <Button Classes="popupAction" Content="3D ROI" Tag="VolumeRoi" Click="OnMeasurementToolPopupClick" />
                        <Button Classes="popupAction" Content="ROI ball" Tag="BallRoiCorrection" Click="OnMeasurementToolPopupClick" />
                        <Button Classes="popupAction" Content="Pixel lens" Tag="PixelLens" Click="OnMeasurementToolPopupClick" />
                        <Button Classes="popupAction" Content="Modify" Tag="Modify" Click="OnMeasurementToolPopupClick" />
                        <Button Classes="popupAction" Content="Erase" Tag="Erase" Click="OnMeasurementToolPopupClick" />
                    </StackPanel>
                </Border>
            </Popup>

            <Popup x:Name="LayoutPopup" Placement="Top" IsLightDismissEnabled="True" Closed="OnAnyActionPopupClosed">
                <Border Background="#F0262626" BorderBrush="#FF5A5A5A" BorderThickness="1" CornerRadius="8" Padding="8"
                        PointerEntered="OnActionToolbarPointerEntered" PointerExited="OnActionToolbarPointerExited">
                    <StackPanel Width="320" Spacing="10">
                        <StackPanel Spacing="6">
                            <TextBlock Classes="popupSectionTitle" Text="Standard layouts" />
                            <WrapPanel ItemWidth="96" Orientation="Horizontal">
                                <Button Classes="popupAction" Content="1:1" Tag="1x1" Click="OnLayoutPopupClick" />
                                <Button Classes="popupAction" Content="2:1" Tag="2x1" Click="OnLayoutPopupClick" />
                                <Button Classes="popupAction" Content="3:1" Tag="3x1" Click="OnLayoutPopupClick" />
                                <Button Classes="popupAction" Content="2:2" Tag="2x2" Click="OnLayoutPopupClick" />
                                <Button Classes="popupAction" Content="3:2" Tag="3x2" Click="OnLayoutPopupClick" />
                                <Button Classes="popupAction" Content="3:3" Tag="3x3" Click="OnLayoutPopupClick" />
                                <Button Classes="popupAction" Content="4:3" Tag="4x3" Click="OnLayoutPopupClick" />
                            </WrapPanel>
                        </StackPanel>

                        <Border Height="1" Background="#404A4A4A" />

                        <StackPanel Spacing="6">
                            <TextBlock Classes="popupSectionTitle" Text="Custom layout" />
                            <TextBlock Foreground="#FFBDBDBD"
                                       FontSize="11"
                                       Text="Examples: 2:3 for 2 rows with 3 images each, or 1,2 for row 1 = 1 image and row 2 = 2 images." />
                            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                                <TextBox x:Name="CustomLayoutTextBox"
                                         Watermark="e.g. 2:3 or 1,2"
                                         KeyUp="OnCustomLayoutTextBoxKeyUp" />
                                <Button Grid.Column="1" Classes="popupAction" Content="Apply" Click="OnApplyCustomLayoutClick" />
                                <Button Grid.Column="2" Classes="popupAction" Content="Save" Click="OnSaveCustomLayoutClick" />
                            </Grid>
                        </StackPanel>

                        <Border Height="1" Background="#404A4A4A" />

                        <StackPanel Spacing="6">
                            <TextBlock Classes="popupSectionTitle" Text="Saved custom layouts" />
                            <WrapPanel x:Name="SavedCustomLayoutsPanel" ItemWidth="148" Orientation="Horizontal" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Popup>
        </Grid>
    </Grid>
</Window>
