<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="KPACS.Viewer.PseudonymizeWindow"
        Title="Pseudonymize Study"
        Width="420" Height="280"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="#FF232323">
    <Grid RowDefinitions="Auto,*,Auto" Margin="16">
        <TextBlock Text="Update the patient-identifying headers in the files and SQLite database."
                   Foreground="#FFCCCCCC"
                   TextWrapping="Wrap" />

                <Grid Grid.Row="1" Margin="0,16,0,16"
                            RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="140,*">
            <TextBlock Grid.Row="0" Text="Patient Name" VerticalAlignment="Center" />
                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="PatientNameBox" Text="PSEUDONYMIZED^PATIENT" Margin="10,0,0,0" />

                        <TextBlock Grid.Row="1" Text="Patient ID" VerticalAlignment="Center" Margin="0,10,0,0" />
                        <TextBox Grid.Row="1" Grid.Column="1" x:Name="PatientIdBox" Margin="10,10,0,0" />

                        <TextBlock Grid.Row="2" Text="Accession Number" VerticalAlignment="Center" Margin="0,10,0,0" />
                        <TextBox Grid.Row="2" Grid.Column="1" x:Name="AccessionBox" Margin="10,10,0,0" />

                        <TextBlock Grid.Row="3" Text="Referring Physician" VerticalAlignment="Center" Margin="0,10,0,0" />
                        <TextBox Grid.Row="3" Grid.Column="1" x:Name="ReferringPhysicianBox" Margin="10,10,0,0" />
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Content="Cancel" Click="OnCancelClick" MinWidth="90" />
            <Button Content="Apply" Click="OnApplyClick" MinWidth="90" Classes="accent" />
        </StackPanel>
    </Grid>
</Window>
