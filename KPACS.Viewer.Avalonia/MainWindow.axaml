<Window xmlns="https://github.com/avaloniaui"
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                x:Class="KPACS.Viewer.MainWindow"
                Title="K-PACS Study Browser"
                Icon="/Assets/Branding/k-pacs.png"
                Width="1480" Height="940"
                MinWidth="1180" MinHeight="780"
                WindowStartupLocation="CenterScreen"
                Background="#FFD0D0D0">
        <Window.Styles>
                <Style Selector="Button.action">
                        <Setter Property="Background" Value="#FF22A7DA" />
                        <Setter Property="Foreground" Value="White" />
                        <Setter Property="Padding" Value="10,8" />
                        <Setter Property="MinHeight" Value="38" />
                </Style>
                <Style Selector="TextBox">
                        <Setter Property="Background" Value="#FFF7F7F7" />
                        <Setter Property="Foreground" Value="#FF202020" />
                        <Setter Property="BorderBrush" Value="#FF8C8C8C" />
                        <Setter Property="Height" Value="30" />
                </Style>
                <Style Selector="ComboBox">
                        <Setter Property="Background" Value="#FFF7F7F7" />
                        <Setter Property="Foreground" Value="#FF202020" />
                        <Setter Property="BorderBrush" Value="#FF8C8C8C" />
                        <Setter Property="MinHeight" Value="30" />
                </Style>
                <Style Selector="CheckBox.modality-filter">
                        <Setter Property="Margin" Value="0,0,8,6" />
                        <Setter Property="MinWidth" Value="44" />
                </Style>
                <Style Selector="Border.section">
                        <Setter Property="Background" Value="#FFE3E3E3" />
                        <Setter Property="BorderBrush" Value="#FF9E9E9E" />
                        <Setter Property="BorderThickness" Value="1" />
                </Style>
                <Style Selector="DataGrid">
                        <Setter Property="Background" Value="#FFF9F9F9" />
                        <Setter Property="Foreground" Value="#FF202020" />
                        <Setter Property="BorderBrush" Value="#FF9E9E9E" />
                </Style>
                <Style Selector="DataGridRow">
                        <Setter Property="Background" Value="#FFF2F2F2" />
                </Style>
                <Style Selector="DataGridRow:nth-child(even)">
                        <Setter Property="Background" Value="#FFEAEAEA" />
                </Style>
                <Style Selector="Border.networkInfoCard">
                        <Setter Property="Background" Value="#FFF9FBFD" />
                        <Setter Property="BorderBrush" Value="#FFD5E0E8" />
                        <Setter Property="BorderThickness" Value="1" />
                        <Setter Property="CornerRadius" Value="10" />
                        <Setter Property="Padding" Value="10" />
                        <Setter Property="MinHeight" Value="76" />
                </Style>
                <Style Selector="TextBlock.networkCardIcon">
                        <Setter Property="FontSize" Value="18" />
                </Style>
                <Style Selector="TextBlock.networkCardTitle">
                        <Setter Property="FontSize" Value="12" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="Foreground" Value="#FF23313B" />
                </Style>
                <Style Selector="TextBlock.networkCardBody">
                        <Setter Property="Foreground" Value="#FF5A6770" />
                        <Setter Property="TextWrapping" Value="NoWrap" />
                        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                        <Setter Property="FontSize" Value="11" />
                </Style>
                <Style Selector="TabControl.compactTabs">
                        <Setter Property="Padding" Value="0" />
                </Style>
                <Style Selector="TabControl.compactTabs TabItem">
                        <Setter Property="Padding" Value="10,4" />
                        <Setter Property="MinHeight" Value="28" />
                </Style>
                <Style Selector="TabControl.compactTabs TabItem /template/ ContentPresenter#PART_ContentPresenter">
                        <Setter Property="Margin" Value="0" />
                </Style>
        </Window.Styles>

        <Grid>
                <DockPanel>
                <Border DockPanel.Dock="Top" Background="#FFCFCFCF" BorderBrush="#FF9E9E9E" BorderThickness="0,0,0,1" Padding="8">
                        <Grid ColumnDefinitions="4.8*,2.2*">
                                <Border Classes="section" Padding="8">
                                        <Grid ColumnDefinitions="104,170,170,170,178" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="8">
                                                <TextBlock Grid.Row="0" Grid.ColumnSpan="5" Text="Search filter" FontWeight="Bold" Foreground="#FF333333" />

                                                <StackPanel Grid.Row="1" Grid.RowSpan="3" Grid.Column="0" Spacing="8">
                                                        <Button Classes="action" Width="96" Content="Search" Click="OnSearchClick" />
                                                        <Button Width="96" Height="30" Content="Today" Click="OnTodayClick" />
                                                        <Button Width="96" Height="30" Content="Yesterday" Click="OnYesterdayClick" />
                                                        <Button Width="96" Height="30" Content="Clear entries" Click="OnClearClick" />
                                                </StackPanel>

                                                <StackPanel Grid.Row="1" Grid.Column="1" Spacing="2">
                                                        <TextBlock Text="Patient ID" Foreground="#FF333333" />
                                                        <TextBox x:Name="PatientIdBox" Width="170" />
                                                </StackPanel>
                                                <StackPanel Grid.Row="1" Grid.Column="2" Spacing="2">
                                                        <TextBlock Text="Patient name" Foreground="#FF333333" />
                                                        <TextBox x:Name="PatientNameBox" Width="170" />
                                                </StackPanel>
                                                <StackPanel Grid.Row="1" Grid.Column="3" Spacing="2">
                                                        <TextBlock Text="Referring physician" Foreground="#FF333333" />
                                                        <TextBox x:Name="ReferringPhysicianBox" Width="170" />
                                                </StackPanel>
                                                <Border Grid.Row="1" Grid.RowSpan="3" Grid.Column="4" BorderBrush="#FF9E9E9E" BorderThickness="1" Padding="8,6">
                                                        <StackPanel Spacing="6">
                                                                <TextBlock Text="Modality filter" Foreground="#FF333333" FontWeight="SemiBold" />
                                                                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="2">
                                                                        <CheckBox Grid.Row="0" Grid.Column="0" x:Name="ModalityUsCheckBox" Classes="modality-filter" Content="US" />
                                                                        <CheckBox Grid.Row="0" Grid.Column="1" x:Name="ModalityCtCheckBox" Classes="modality-filter" Content="CT" />
                                                                        <CheckBox Grid.Row="1" Grid.Column="0" x:Name="ModalityMrCheckBox" Classes="modality-filter" Content="MR" />
                                                                        <CheckBox Grid.Row="1" Grid.Column="1" x:Name="ModalityDrCheckBox" Classes="modality-filter" Content="DR" />
                                                                        <CheckBox Grid.Row="2" Grid.Column="0" x:Name="ModalityOtCheckBox" Classes="modality-filter" Content="OT" />
                                                                        <CheckBox Grid.Row="2" Grid.Column="1" x:Name="ModalityScCheckBox" Classes="modality-filter" Content="SC" />
                                                                        <CheckBox Grid.Row="3" Grid.Column="0" x:Name="ModalitySrCheckBox" Classes="modality-filter" Content="SR" />
                                                                        <CheckBox Grid.Row="3" Grid.Column="1" x:Name="ModalityRfCheckBox" Classes="modality-filter" Content="RF" />
                                                                        <CheckBox Grid.Row="4" Grid.Column="0" x:Name="ModalityNmCheckBox" Classes="modality-filter" Content="NM" />
                                                                        <CheckBox Grid.Row="4" Grid.Column="1" x:Name="ModalityCrCheckBox" Classes="modality-filter" Content="CR" />
                                                                        <CheckBox Grid.Row="5" Grid.Column="0" x:Name="ModalityXaCheckBox" Classes="modality-filter" Content="XA" />
                                                                        <CheckBox Grid.Row="5" Grid.Column="1" x:Name="ModalityMgCheckBox" Classes="modality-filter" Content="MG" />
                                                                </Grid>
                                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                                        <Button Width="72" Height="30" Content="All" Click="OnAllModalitiesClick" />
                                                                        <Button Width="72" Height="30" Content="Clear" Click="OnClearModalitiesClick" />
                                                                </StackPanel>
                                                        </StackPanel>
                                                </Border>

                                                <StackPanel Grid.Row="2" Grid.Column="1" Spacing="2">
                                                        <TextBlock Text="Accession no." Foreground="#FF333333" />
                                                        <TextBox x:Name="AccessionBox" Width="170" />
                                                </StackPanel>
                                                <StackPanel Grid.Row="2" Grid.Column="2" Spacing="2">
                                                        <TextBlock Text="Study description" Foreground="#FF333333" />
                                                        <TextBox x:Name="StudyDescriptionBox" Width="170" />
                                                </StackPanel>
                                                <StackPanel Grid.Row="2" Grid.Column="3" Spacing="2">
                                                        <TextBlock Text="Quick search" Foreground="#FF333333" />
                                                        <TextBox x:Name="QuickSearchBox" Width="170" />
                                                </StackPanel>

                                                <StackPanel Grid.Row="3" Grid.Column="1" Spacing="2">
                                                        <TextBlock Text="From study date" Foreground="#FF333333" />
                                                        <TextBox x:Name="FromDateBox" Width="170" Watermark="dd.MM.yyyy" />
                                                </StackPanel>
                                                <StackPanel Grid.Row="3" Grid.Column="2" Spacing="2">
                                                        <TextBlock Text="To study date" Foreground="#FF333333" />
                                                        <TextBox x:Name="ToDateBox" Width="170" Watermark="dd.MM.yyyy" />
                                                </StackPanel>
                                                <StackPanel Grid.Row="3" Grid.Column="3" Spacing="2">
                                                        <TextBlock Text="Patient birth date" Foreground="#FF333333" />
                                                        <TextBox x:Name="PatientBirthDateBox" Width="170" Watermark="dd.MM.yyyy" />
                                                </StackPanel>

                                        </Grid>
                                </Border>

                                <Grid Grid.Column="1" RowDefinitions="Auto,*" Margin="8,0,0,0">
                                        <Border Classes="section" Padding="6" Margin="0,0,0,8">
                                                <Grid ColumnDefinitions="*,Auto,Auto">
                                                        <StackPanel>
                                                                <TextBlock Text="Query" FontWeight="Bold" Foreground="#FF333333" />
                                                                <TextBlock x:Name="DatabaseStatsText" Foreground="#FF5F5F5F" Margin="0,4,0,0" />
                                                        </StackPanel>
                                                        <Button x:Name="ConfigButton" Grid.Column="1" Width="56" Classes="action" Content="Cfg" Click="OnConfigClick" />
                                                        <Button x:Name="InfoButton" Grid.Column="2" Width="56" Classes="action" Content="Info" Click="OnInfoClick" />
                                                </Grid>
                                        </Border>

                                        <Border Classes="section" Padding="6">
                                                <TabControl x:Name="BrowserModeTabs" SelectionChanged="OnBrowserModeChanged">
                                                        <TabItem Header="Network">
                                                                <StackPanel Margin="6" Spacing="6">
                                                                        <TextBlock Text="Network query and health overview." Foreground="#FF555555" />
                                                                        <Border x:Name="NetworkConfigurationHintBorder" Background="#FFF8F1D9" BorderBrush="#FFE3C67A" BorderThickness="1" CornerRadius="10" Padding="8" IsVisible="False">
                                                                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                                                                        <TextBlock Text="⚙" FontSize="16" VerticalAlignment="Top" />
                                                                                        <StackPanel Grid.Column="1" Spacing="2">
                                                                                                <TextBlock Text="Network setup needed" FontWeight="SemiBold" Foreground="#FF5A430F" />
                                                                                                <TextBlock x:Name="NetworkConfigurationHintText" TextWrapping="Wrap" Foreground="#FF7A6532" />
                                                                                        </StackPanel>
                                                                                        <Button Grid.Column="2" Content="Configure" MinHeight="28" Click="OnConfigClick" />
                                                                                </Grid>
                                                                        </Border>

                                                                        <Border Background="#FFF2F6FA" BorderBrush="#FFD3DEE7" BorderThickness="1" CornerRadius="12" Padding="6">
                                                                                <StackPanel Margin="0,8,0,0" Spacing="8">
                                                                                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                                                                                <TextBlock Text="Network health" FontWeight="Bold" FontSize="14" Foreground="#FF25343E" VerticalAlignment="Center" />
                                                                                                <Button Grid.Column="1" Content="Configure" Click="OnConfigClick" />
                                                                                                <Button Grid.Column="2" Content="Details" Click="OnInfoClick" />
                                                                                        </Grid>

                                                                                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto" ColumnSpacing="8" RowSpacing="8">
                                                                                                <Border Classes="networkInfoCard">
                                                                                                        <StackPanel Spacing="6">
                                                                                                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                                                                                                        <TextBlock Classes="networkCardIcon" Text="☁" />
                                                                                                                        <TextBlock Grid.Column="1" Classes="networkCardTitle" Text="Remote archive" VerticalAlignment="Center" />
                                                                                                                        <Border x:Name="RemoteArchiveBadge" Grid.Column="2" CornerRadius="9" Padding="8,2" Background="#FFE7EDF2">
                                                                                                                                <TextBlock x:Name="RemoteArchiveBadgeText" Foreground="#FF41515D" FontSize="11" FontWeight="SemiBold" />
                                                                                                                        </Border>
                                                                                                                </Grid>
                                                                                                                <TextBlock x:Name="RemoteArchivePrimaryText" Classes="networkCardBody" />
                                                                                                                <TextBlock x:Name="RemoteArchiveSecondaryText" Classes="networkCardBody" />
                                                                                                        </StackPanel>
                                                                                                </Border>

                                                                                                <Border Grid.Column="1" Classes="networkInfoCard">
                                                                                                        <StackPanel Spacing="6">
                                                                                                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                                                                                                        <TextBlock Classes="networkCardIcon" Text="📥" />
                                                                                                                        <TextBlock Grid.Column="1" Classes="networkCardTitle" Text="Storage SCP / Inbox" VerticalAlignment="Center" />
                                                                                                                        <Border x:Name="StorageScpBadge" Grid.Column="2" CornerRadius="9" Padding="8,2" Background="#FFE7EDF2">
                                                                                                                                <TextBlock x:Name="StorageScpBadgeText" Foreground="#FF41515D" FontSize="11" FontWeight="SemiBold" />
                                                                                                                        </Border>
                                                                                                                </Grid>
                                                                                                                <TextBlock x:Name="StorageScpPrimaryText" Classes="networkCardBody" />
                                                                                                                <TextBlock x:Name="StorageScpSecondaryText" Classes="networkCardBody" />
                                                                                                        </StackPanel>
                                                                                                </Border>
                                                                                        </Grid>
                                                                                </StackPanel>
                                                                        </Border>
                                                                </StackPanel>
                                                        </TabItem>
                                                        <TabItem Header="Database">
                                                                <StackPanel Margin="6" Spacing="6">
                                                                        <TextBlock Text="SQLite-backed K-PACS imagebox." Foreground="#FF555555" />
                                                                        <Border Background="#FFF2F6FA" BorderBrush="#FFD3DEE7" BorderThickness="1" CornerRadius="12" Padding="6">
                                                                                <StackPanel Margin="0,8,0,0" Spacing="8">
                                                                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                                                                <TextBlock Text="Database health" FontWeight="Bold" FontSize="14" Foreground="#FF25343E" VerticalAlignment="Center" />
                                                                                                <Button Grid.Column="1" Content="Details" Click="OnInfoClick" />
                                                                                        </Grid>

                                                                                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto" ColumnSpacing="8" RowSpacing="8">
                                                                                                <Border Classes="networkInfoCard">
                                                                                                        <StackPanel Spacing="6">
                                                                                                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                                                                                                        <TextBlock Classes="networkCardIcon" Text="🗄" />
                                                                                                                        <TextBlock Grid.Column="1" Classes="networkCardTitle" Text="Local imagebox" VerticalAlignment="Center" />
                                                                                                                        <Border x:Name="LocalDatabaseBadge" Grid.Column="2" CornerRadius="9" Padding="8,2" Background="#FFE7EDF2">
                                                                                                                                <TextBlock x:Name="LocalDatabaseBadgeText" Foreground="#FF41515D" FontSize="11" FontWeight="SemiBold" />
                                                                                                                        </Border>
                                                                                                                </Grid>
                                                                                                                <TextBlock x:Name="LocalDatabasePrimaryText" Classes="networkCardBody" />
                                                                                                                <TextBlock x:Name="LocalDatabaseSecondaryText" Classes="networkCardBody" />
                                                                                                        </StackPanel>
                                                                                                </Border>

                                                                                                <Border Grid.Column="1" Classes="networkInfoCard">
                                                                                                        <StackPanel Spacing="6">
                                                                                                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                                                                                                        <TextBlock Classes="networkCardIcon" Text="💾" />
                                                                                                                        <TextBlock Grid.Column="1" Classes="networkCardTitle" Text="Drive space" VerticalAlignment="Center" />
                                                                                                                        <Border x:Name="DiskHealthBadge" Grid.Column="2" CornerRadius="9" Padding="8,2" Background="#FFE7EDF2">
                                                                                                                                <TextBlock x:Name="DiskHealthBadgeText" Foreground="#FF41515D" FontSize="11" FontWeight="SemiBold" />
                                                                                                                        </Border>
                                                                                                                </Grid>
                                                                                                                <TextBlock x:Name="DiskHealthPrimaryText" Classes="networkCardBody" />
                                                                                                                <TextBlock x:Name="DiskHealthSecondaryText" Classes="networkCardBody" />
                                                                                                        </StackPanel>
                                                                                                </Border>
                                                                                        </Grid>
                                                                                </StackPanel>
                                                                        </Border>
                                                                </StackPanel>
                                                        </TabItem>
                                                        <TabItem Header="Filesystem">
                                                                <StackPanel Margin="6" Spacing="6">
                                                                        <TextBlock Text="Import folders or DICOMDIR media into the imagebox." Foreground="#FF555555" />
                                                                        <Border Background="#FFF2F6FA" BorderBrush="#FFD3DEE7" BorderThickness="1" CornerRadius="12" Padding="6">
                                                                                <StackPanel Margin="0,8,0,0" Spacing="8">
                                                                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                                                                <TextBlock Text="Import jobs" FontWeight="SemiBold" Foreground="#FF25343E" VerticalAlignment="Center" />
                                                                                                <Button Grid.Column="1" Content="Job log" Click="OnViewBackgroundJobLogClick" />
                                                                                        </Grid>
                                                                                        <TextBlock x:Name="BackgroundJobsSummaryText" Classes="networkCardBody" />
                                                                                        <DataGrid x:Name="BackgroundJobsGrid"
                                                                                                  AutoGenerateColumns="False"
                                                                                                  HeadersVisibility="Column"
                                                                                                  CanUserResizeColumns="True"
                                                                                                  CanUserSortColumns="True"
                                                                                                  IsReadOnly="True"
                                                                                                  MinHeight="150"
                                                                                                  MaxHeight="190">
                                                                                                <DataGrid.Columns>
                                                                                                        <DataGridTextColumn Header="Type" Binding="{Binding TypeLabel}" Width="90" />
                                                                                                        <DataGridTextColumn Header="Study / Job" Binding="{Binding Title}" Width="2*" />
                                                                                                        <DataGridTextColumn Header="State" Binding="{Binding StateLabel}" Width="120" />
                                                                                                        <DataGridTextColumn Header="Progress" Binding="{Binding ProgressLabel}" Width="150" />
                                                                                                        <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" Width="3*" />
                                                                                                </DataGrid.Columns>
                                                                                        </DataGrid>
                                                                                </StackPanel>
                                                                        </Border>
                                                                </StackPanel>
                                                        </TabItem>
                                                        <TabItem Header="Email">
                                                                <StackPanel Margin="6" Spacing="8">
                                                                        <TextBlock Text="Receive studies through the secure relay. Set it up once, then refresh and use Download + Import." Foreground="#FF555555" TextWrapping="Wrap" />
                                                                        <Border Background="#FFF2F6FA" BorderBrush="#FFD3DEE7" BorderThickness="1" CornerRadius="12" Padding="8">
                                                                                <StackPanel Spacing="8">
                                                                                        <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
                                                                                                <TextBlock Text="Relay inbox" FontWeight="SemiBold" Foreground="#FF25343E" VerticalAlignment="Center" />
                                                                                                <Button Grid.Column="1" Content="Set up relay" Click="OnRelaySetupClick" />
                                                                                                <Button x:Name="RelayInboxRefreshButton" Grid.Column="2" Content="Refresh" Click="OnRefreshRelayInboxClick" />
                                                                                                <Button x:Name="RelayInboxDownloadButton" Grid.Column="3" Content="Download + Import" Click="OnRelayDownloadImportClick" />
                                                                                        </Grid>
                                                                                        <TextBlock x:Name="RelayInboxSummaryText" Classes="networkCardBody" TextWrapping="Wrap" />
                                                                                        <TextBlock x:Name="RelayInboxStatusText" Classes="networkCardBody" TextWrapping="Wrap" />
                                                                                        <DataGrid x:Name="RelayInboxGrid"
                                                                                                  AutoGenerateColumns="False"
                                                                                                  HeadersVisibility="Column"
                                                                                                  CanUserResizeColumns="True"
                                                                                                  CanUserSortColumns="True"
                                                                                                  IsReadOnly="True"
                                                                                                  MinHeight="170"
                                                                                                  MaxHeight="220"
                                                                                                  SelectionChanged="OnRelayInboxSelectionChanged">
                                                                                                <DataGrid.Columns>
                                                                                                        <DataGridTextColumn Header="From" Binding="{Binding SenderLabel}" Width="2*" />
                                                                                                        <DataGridTextColumn Header="Subject" Binding="{Binding Subject}" Width="2*" />
                                                                                                        <DataGridTextColumn Header="Received" Binding="{Binding AgeLabel}" Width="130" />
                                                                                                        <DataGridTextColumn Header="Package" Binding="{Binding PackageLabel}" Width="2*" />
                                                                                                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120" />
                                                                                                </DataGrid.Columns>
                                                                                        </DataGrid>
                                                                                </StackPanel>
                                                                        </Border>
                                                                </StackPanel>
                                                        </TabItem>
                                                </TabControl>
                                        </Border>
                                </Grid>
                        </Grid>
                </Border>

                <Border DockPanel.Dock="Bottom" Background="#FFC7C7C7" BorderBrush="#FF9E9E9E" BorderThickness="0,1,0,0" Padding="8,4">
                        <TextBlock x:Name="StatusText" FontFamily="Consolas" Foreground="#FF222222" />
                </Border>

                <Grid x:Name="BrowserContentGrid" Margin="8" RowDefinitions="*,6,190">
                        <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="74" />
                                <ColumnDefinition Width="320" />
                                <ColumnDefinition Width="6" />
                                <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.RowSpan="3" Classes="section" Padding="6">
                                <StackPanel Spacing="8">
                                        <TextBlock Text="Actions" FontWeight="Bold" Foreground="#FF333333" HorizontalAlignment="Center" Margin="0,0,0,4" />
                                        <Button x:Name="ViewActionButton" Classes="action" Content="View" Click="OnOpenViewerClick" />
                                        <Button x:Name="SendActionButton" Classes="action" Content="Send" Click="OnSendSelectedClick" />
                                        <Button x:Name="RelayActionButton" Classes="action" Content="Share" Click="OnRelayShareClick" />
                                        <Button x:Name="ModifyActionButton" Classes="action" Content="Modify" Click="OnPseudonymizeClick" />
                                        <Button x:Name="GuideActionButton" Content="Guide" Click="OnGuideClick" ToolTip.Tip="Show the onboarding tour again." />
                                        <StackPanel Spacing="4" Margin="0,8,0,0">
                                                <TextBlock Text="Viewer windows" Foreground="#FF555555" HorizontalAlignment="Center" />
                                                <ComboBox x:Name="ViewerWindowCountComboBox" Width="58" HorizontalAlignment="Center" SelectionChanged="OnViewerWindowCountChanged">
                                                        <ComboBoxItem Content="1" />
                                                        <ComboBoxItem Content="2" />
                                                        <ComboBoxItem Content="3" />
                                                        <ComboBoxItem Content="4" />
                                                </ComboBox>
                                        </StackPanel>
                                </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Classes="section" Padding="4" Margin="8,0,8,8">
                                <Grid>
                                        <Grid x:Name="PatientPanel" RowDefinitions="Auto,*">
                                                <Grid ColumnDefinitions="*,Auto" Margin="4,4,4,6">
                                                        <TextBlock Text="Patients" FontWeight="Bold" Foreground="#FF333333" VerticalAlignment="Center" />
                                                        <Button x:Name="HidePatientPanelButton" Grid.Column="1" Width="56" Height="28" Content="Hide" Click="OnTogglePatientPanelClick" />
                                                </Grid>
                                                <DataGrid x:Name="PatientGrid" Grid.Row="1"
                                                                  AutoGenerateColumns="False"
                                                                  CanUserResizeColumns="True"
                                                                  CanUserSortColumns="True"
                                                                  GridLinesVisibility="All"
                                                                  HeadersVisibility="Column"
                                                                  IsReadOnly="True"
                                                                  SelectionMode="Single"
                                                                  SelectionChanged="OnPatientSelectionChanged">
                                                        <DataGrid.Columns>
                                                                <DataGridTextColumn Header="Patient name" Binding="{Binding PatientName}" Width="*" />
                                                                <DataGridTextColumn Header="DOB" Binding="{Binding PatientBirthDate}" Width="92" />
                                                                <DataGridTextColumn Header="Studies" Binding="{Binding StudyCount}" Width="64" />
                                                        </DataGrid.Columns>
                                                </DataGrid>
                                        </Grid>

                                        <Grid x:Name="FilesystemPanel" IsVisible="False" RowDefinitions="Auto,Auto,Auto,*">
                                                <TextBlock Text="Filesystem" FontWeight="Bold" Foreground="#FF333333" Margin="4,4,4,2" />
                                                <TextBlock x:Name="FilesystemRootText" Grid.Row="1" Margin="4,0,4,6" Foreground="#FF555555" TextWrapping="Wrap" />
                                                <StackPanel x:Name="FilesystemScanProgressPanel" Grid.Row="2" Margin="4,0,4,6" Spacing="4" IsVisible="False">
                                                        <TextBlock x:Name="FilesystemScanProgressText" Foreground="#FF555555" TextWrapping="Wrap" />
                                                        <ProgressBar x:Name="FilesystemScanProgressBar" Height="10" IsIndeterminate="True" Minimum="0" Maximum="100" />
                                                </StackPanel>
                                                <Grid Grid.Row="3">
                                                        <TextBlock x:Name="FilesystemHintText" Margin="8" Foreground="#FF666666" Text="Expand Computer, choose a drive or folder, then right-click it and select Scan folder." TextWrapping="Wrap" />
                                                        <TreeView x:Name="FilesystemTreeView"
                                                                  IsVisible="False"
                                                                  PointerPressed="OnFilesystemTreePointerPressed"
                                                                  KeyDown="OnFilesystemTreeKeyDown"
                                                                  SelectionChanged="OnFilesystemTreeSelectionChanged">
                                                                <TreeView.ItemTemplate>
                                                                        <TreeDataTemplate ItemsSource="{Binding Children}">
                                                                                <TextBlock Text="{Binding DisplayName}" />
                                                                        </TreeDataTemplate>
                                                                </TreeView.ItemTemplate>
                                                                <TreeView.ContextMenu>
                                                                        <ContextMenu Opened="OnFilesystemContextMenuOpened">
                                                                                <MenuItem x:Name="ScanFolderMenuItem" Header="Scan folder" Click="OnScanFolderClick" />
                                                                        </ContextMenu>
                                                                </TreeView.ContextMenu>
                                                        </TreeView>
                                                </Grid>
                                        </Grid>

                                        <Border x:Name="ModePlaceholderPanel" IsVisible="False" Background="#FFEAEAEA" Padding="8">
                                                <TextBlock x:Name="ModePlaceholderText" Foreground="#FF666666" TextWrapping="Wrap" VerticalAlignment="Center" />
                                        </Border>
                                </Grid>
                        </Border>

                        <GridSplitter x:Name="PatientStudySplitter"
                                      Grid.Column="2"
                                      Margin="0,0,8,8"
                                      Background="#FFB8B8B8"
                                      ResizeDirection="Columns"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch"
                                      PointerReleased="OnPatientStudySplitterPointerReleased" />

                        <Border Grid.Column="3" Classes="section" Padding="4" Margin="0,0,0,8">
                                <Grid RowDefinitions="Auto,*">
                                        <Grid ColumnDefinitions="*,Auto" Margin="4,4,4,6">
                                                <StackPanel>
                                                        <TextBlock Text="Studies" FontWeight="Bold" Foreground="#FF333333" />
                                                        <TextBlock x:Name="StudySummaryText" Foreground="#FF555555" FontSize="12" />
                                                </StackPanel>
                                                <Button x:Name="ShowPatientPanelButton" Grid.Column="1" Width="108" Height="30" Margin="8,0,0,0" Content="Show patients" Click="OnTogglePatientPanelClick" />
                                        </Grid>
                                        <DataGrid x:Name="StudyGrid" Grid.Row="1"
                                                          AutoGenerateColumns="False"
                                                          CanUserResizeColumns="True"
                                                          CanUserSortColumns="True"
                                                          GridLinesVisibility="All"
                                                          HeadersVisibility="Column"
                                                          IsReadOnly="True"
                                                          SelectionMode="Extended"
                                                          PointerPressed="OnStudyGridPointerPressed"
                                                          SelectionChanged="OnStudySelectionChanged"
                                                          DoubleTapped="OnStudyDoubleTapped">
                                                <DataGrid.ContextMenu>
                                                        <ContextMenu Opened="OnStudyContextMenuOpened">
                                                                <MenuItem x:Name="DeleteStudyMenuItem" Header="Delete Study" Click="OnDeleteStudyClick" />
                                                        </ContextMenu>
                                                </DataGrid.ContextMenu>
                                                <DataGrid.Columns>
                                                        <DataGridTextColumn Header="Modality" Binding="{Binding Modalities}" Width="88" />
                                                        <DataGridTextColumn Header="Status" Binding="{Binding SeriesCount}" Width="68" />
                                                        <DataGridTextColumn Header="Patient name" Binding="{Binding PatientName}" Width="170" />
                                                        <DataGridTextColumn Header="Patient ID" Binding="{Binding PatientId}" Width="120" />
                                                        <DataGridTextColumn Header="Date of birth" Binding="{Binding DisplayPatientBirthDate}" Width="110" />
                                                        <DataGridTextColumn Header="Study date" Binding="{Binding DisplayStudyDate}" Width="100" />
                                                        <DataGridTextColumn Header="Referring phys." Binding="{Binding ReferringPhysician}" Width="150" />
                                                        <DataGridTextColumn Header="Description" Binding="{Binding StudyDescription}" Width="*" />
                                                        <DataGridTextColumn Header="Accession no." Binding="{Binding AccessionNumber}" Width="120" />
                                                </DataGrid.Columns>
                                        </DataGrid>
                                </Grid>
                        </Border>

                        <GridSplitter x:Name="StudySeriesSplitter"
                                      Grid.Row="1"
                                      Grid.Column="1"
                                      Grid.ColumnSpan="3"
                                      Height="6"
                                      Margin="8,0,0,0"
                                      Background="#FFB8B8B8"
                                      ResizeDirection="Rows"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch"
                                      PointerReleased="OnStudySeriesSplitterPointerReleased" />

                        <Border Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" Classes="section" Padding="4" Margin="8,0,0,0">
                                <Grid RowDefinitions="Auto,*">
                                        <TextBlock Text="Series overview" FontWeight="Bold" Foreground="#FF333333" Margin="4,4,4,6" />
                                        <DataGrid x:Name="SeriesGrid" Grid.Row="1"
                                                          AutoGenerateColumns="False"
                                                          CanUserResizeColumns="True"
                                                          CanUserSortColumns="True"
                                                          GridLinesVisibility="All"
                                                          HeadersVisibility="Column"
                                                          IsReadOnly="True"
                                                          SelectionMode="Single">
                                                <DataGrid.Columns>
                                                        <DataGridTextColumn Header="Series" Binding="{Binding SeriesNumber}" Width="80" />
                                                        <DataGridTextColumn Header="Modality" Binding="{Binding Modality}" Width="90" />
                                                        <DataGridTextColumn Header="Description" Binding="{Binding SeriesDescription}" Width="*" />
                                                        <DataGridTextColumn Header="Images" Binding="{Binding InstanceCount}" Width="90" />
                                                        <DataGridTextColumn Header="First file" Binding="{Binding FirstFileName}" Width="230" />
                                                </DataGrid.Columns>
                                        </DataGrid>
                                </Grid>
                        </Border>
                </Grid>
                </DockPanel>

                <Border x:Name="OnboardingOverlay"
                        Background="#A6000000"
                        IsVisible="False"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch">
                        <Border Width="680"
                                MaxWidth="680"
                                Padding="18"
                                CornerRadius="16"
                                Background="#FFF9FBFD"
                                BorderBrush="#FFD0DCE5"
                                BorderThickness="1"
                                BoxShadow="0 18 48 0 #70000000"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                                <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" RowSpacing="12">
                                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                                                <StackPanel>
                                                        <TextBlock Text="Welcome to K-PACS" FontWeight="Bold" FontSize="20" Foreground="#FF21303A" />
                                                        <TextBlock x:Name="OnboardingStepText" Foreground="#FF5A6770" Margin="0,4,0,0" />
                                                </StackPanel>
                                                <Border x:Name="OnboardingModeBadge" Grid.Column="1" Background="#FFE7EDF2" CornerRadius="10" Padding="10,4" VerticalAlignment="Center" IsVisible="False">
                                                        <TextBlock x:Name="OnboardingModeBadgeText" Foreground="#FF41515D" FontWeight="SemiBold" FontSize="11" />
                                                </Border>
                                                <Button Grid.Column="2" Content="Skip" MinWidth="72" Click="OnOnboardingSkipClick" />
                                        </Grid>

                                        <TextBlock x:Name="OnboardingTitleText" Grid.Row="1" FontWeight="SemiBold" FontSize="17" Foreground="#FF25343E" TextWrapping="Wrap" />
                                        <TextBlock x:Name="OnboardingSummaryText" Grid.Row="2" Foreground="#FF4F5E68" TextWrapping="Wrap" />

                                        <Border Grid.Row="3" Background="#FFF2F6FA" BorderBrush="#FFD3DEE7" BorderThickness="1" CornerRadius="12" Padding="14">
                                                <StackPanel Spacing="10">
                                                        <TextBlock Text="What to do" FontWeight="Bold" Foreground="#FF25343E" />
                                                        <TextBlock x:Name="OnboardingTipsText" Foreground="#FF4F5E68" TextWrapping="Wrap" />
                                                        <Border Background="#FFF8F1D9" BorderBrush="#FFE3C67A" BorderThickness="1" CornerRadius="10" Padding="10,8">
                                                                <TextBlock x:Name="OnboardingHintText" Foreground="#FF6C5821" TextWrapping="Wrap" />
                                                        </Border>
                                                </StackPanel>
                                        </Border>

                                        <Grid Grid.Row="4" ColumnDefinitions="Auto,Auto,*,Auto,Auto" ColumnSpacing="10">
                                                <Button x:Name="OnboardingToastButton" Content="Tip again" MinWidth="88" Click="OnOnboardingToastClick" />
                                                <Button x:Name="OnboardingPrimaryActionButton" Grid.Column="1" Content="Try it" MinWidth="120" Click="OnOnboardingPrimaryActionClick" IsVisible="False" />
                                                <TextBlock Grid.Column="2" VerticalAlignment="Center" Foreground="#FF5A6770" Text="You can reopen this tour any time with Guide." TextWrapping="Wrap" />
                                                <Button x:Name="OnboardingPreviousButton" Grid.Column="3" Content="Previous" MinWidth="88" Click="OnOnboardingPreviousClick" />
                                                <Button x:Name="OnboardingNextButton" Grid.Column="4" Classes="action" Content="Next" MinWidth="88" Click="OnOnboardingNextClick" />
                                        </Grid>
                                </Grid>
                        </Border>
                </Border>

                <ItemsControl x:Name="ToastItemsControl"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Top"
                              Margin="0,16,16,0"
                              IsHitTestVisible="False">
                        <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                        <StackPanel Spacing="8" />
                                </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                        <Border Background="{Binding Background}"
                                                BorderBrush="{Binding BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="10,8"
                                                MinWidth="260"
                                                MaxWidth="420"
                                                BoxShadow="0 8 20 0 #50000000">
                                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                                        <TextBlock Text="{Binding Icon}"
                                                                   FontSize="16"
                                                                   VerticalAlignment="Top"
                                                                   Foreground="{Binding Foreground}" />
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding Message}"
                                                                   TextWrapping="Wrap"
                                                                   Foreground="{Binding Foreground}" />
                                                </Grid>
                                        </Border>
                                </DataTemplate>
                        </ItemsControl.ItemTemplate>
                </ItemsControl>
        </Grid>
</Window>
