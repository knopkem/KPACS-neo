{
  "ConnectionStrings": {
    "RelayDb": "Host=localhost;Port=5432;Database=kpacs_share_relay;Username=postgres;Password=postgres"
  },
  "Auth": {
    "RequireApiKey": true,
    "HeaderName": "X-Relay-Api-Key",
    "ApiKeys": [
      "change-me-relay-key"
    ]
  },
  "RateLimiting": {
    "Enabled": true,
    "PermitLimit": 60,
    "WindowSeconds": 60,
    "QueueLimit": 0
  },
  "Storage": {
    "PackagesRoot": "App_Data/packages"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
