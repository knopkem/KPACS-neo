<UserControl x:Class="KPACS.Viewer.Controls.DicomViewPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="True">

    <Grid x:Name="RootGrid" Background="Black" ClipToBounds="True"
          MouseRightButtonDown="OnMouseRightDown"
          MouseRightButtonUp="OnMouseRightUp"
          MouseLeftButtonDown="OnMouseLeftDown"
          MouseLeftButtonUp="OnMouseLeftUp"
          MouseMove="OnMouseMove"
          MouseWheel="OnMouseWheel">

        <!-- DICOM image display -->
        <Image x:Name="DicomImage"
               Stretch="None"
               HorizontalAlignment="Left"
               VerticalAlignment="Top"
               RenderOptions.BitmapScalingMode="HighQuality">
            <Image.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="ZoomTransform" ScaleX="1" ScaleY="1" />
                    <TranslateTransform x:Name="PanTransform" X="0" Y="0" />
                </TransformGroup>
            </Image.RenderTransform>
        </Image>

        <!-- Overlay text: 4 corners like a DICOM viewer -->
        <TextBlock x:Name="OverlayTopLeft"
                   Text="" Foreground="#FFFFDD00" FontFamily="Consolas" FontSize="13"
                   VerticalAlignment="Top" HorizontalAlignment="Left"
                   Margin="10" IsHitTestVisible="False">
            <TextBlock.Effect>
                <DropShadowEffect Color="Black" ShadowDepth="1" BlurRadius="3" Opacity="0.9" />
            </TextBlock.Effect>
        </TextBlock>

        <TextBlock x:Name="OverlayTopRight"
                   Text="" Foreground="#FFFFDD00" FontFamily="Consolas" FontSize="13"
                   VerticalAlignment="Top" HorizontalAlignment="Right"
                   Margin="10" IsHitTestVisible="False" TextAlignment="Right">
            <TextBlock.Effect>
                <DropShadowEffect Color="Black" ShadowDepth="1" BlurRadius="3" Opacity="0.9" />
            </TextBlock.Effect>
        </TextBlock>

        <TextBlock x:Name="OverlayBottomLeft"
                   Text="" Foreground="#FFFFDD00" FontFamily="Consolas" FontSize="13"
                   VerticalAlignment="Bottom" HorizontalAlignment="Left"
                   Margin="10" IsHitTestVisible="False">
            <TextBlock.Effect>
                <DropShadowEffect Color="Black" ShadowDepth="1" BlurRadius="3" Opacity="0.9" />
            </TextBlock.Effect>
        </TextBlock>

        <TextBlock x:Name="OverlayBottomRight"
                   Text="" Foreground="#FFFFDD00" FontFamily="Consolas" FontSize="13"
                   VerticalAlignment="Bottom" HorizontalAlignment="Right"
                   Margin="10" IsHitTestVisible="False" TextAlignment="Right">
            <TextBlock.Effect>
                <DropShadowEffect Color="Black" ShadowDepth="1" BlurRadius="3" Opacity="0.9" />
            </TextBlock.Effect>
        </TextBlock>

        <!-- "No image" placeholder -->
        <TextBlock x:Name="PlaceholderText"
                   Text="Drop a DICOM file here or use File → Open"
                   Foreground="#FF666666" FontSize="16" FontFamily="Segoe UI"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   IsHitTestVisible="False" />
    </Grid>
</UserControl>
